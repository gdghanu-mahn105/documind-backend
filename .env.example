# DocuMind environment example
# Copy this file to .env and fill in your real values.

# Database connection string used by SQLAlchemy
# Use PostgreSQL for Docker Compose deployment
DATABASE_URL="postgresql://postgres:password@localhost:5432/documind"

# If you use MySQL instead, uncomment and update this line:
# DATABASE_URL="mysql+pymysql://root:password@localhost:3306/documind_db"

# OpenAI API key for AI generation
OPENAI_API_KEY="your-openai-api-key"

# Resend API key for email sending
RESEND_API_KEY="your-resend-api-key"

